{
  "name": "tag-list",
  "version": "0.0.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "prettier --check . && eslint . && stylelint ./src/**/*.{css,scss,svelte}",
    "lint:fix": "prettier --write . && eslint . --fix && stylelint ./src/**/*.{css,scss,svelte} --fix",
    "format": "prettier --write .",
    "tests": "jest"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "ts"
    ]
  },
  "browserslist": "last 5 years",
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-typescript"
    ],
    "plugins": [
      "@babel/plugin-transform-runtime"
    ]
  },
  "devDependencies": {
    "@babel/core": "^7.12.10",
    "@babel/plugin-transform-runtime": "^7.12.10",
    "@babel/preset-env": "^7.12.11",
    "@babel/preset-typescript": "^7.12.7",
    "@types/ejs": "^3.0.5",
    "@types/jest": "^26.0.20",
    "@typescript-eslint/eslint-plugin": "^4.13.0",
    "@typescript-eslint/parser": "^4.13.0",
    "babel-loader": "^8.2.2",
    "clean-webpack-plugin": "^3.0.0",
    "css-loader": "^5.0.1",
    "ejs": "^3.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "html-loader": "^1.3.2",
    "html-webpack-plugin": "^4.5.1",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "prettier-plugin-jsdoc": "^1.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "runtypes": "^5.0.1",
    "style-loader": "^2.0.0",
    "toml": "^3.0.0",
    "typescript": "^6.0.2",
    "vite": "^8.1.4",
    "webpack": "^5.15.0",
    "webpack-cli": "^4.3.1",
    "webpack-dev-server": "^6.0.0"
  }
